@model IEnumerable<car1.Models.Car>

@{
    ViewData["Title"] = "Car List";
    var userType = ViewData["UserType"] as string;
}

<!-- Custom CSS -->
<style>
    /* Fullscreen Video Background */
    .video-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
    }

    /* Dark Overlay */
    .overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: -1;
    }

    /* Centered Content */
    .content-container {
        position: relative;
        z-index: 1;
        padding: 30px;
        color: white;
    }

    /* Manufacturer Container */
    .manufacturer-container {
        /*background: rgba(255, 255, 255, 0.1);8*/
        padding: 20px;
        border-radius: 10px;
       /* backdrop-filter: blur(10px);*/
        color: white;
        margin-bottom: 20px;
    }

    /* Card Styling */
    .car-card {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        padding: 15px;
        border-radius: 10px;
        transition: 0.3s;
    }

        .car-card:hover {
            transform: scale(1.05);
        }

    /* Button Styling */
    .btn-primary {
        background: linear-gradient(90deg, #ff416c, #ff4b2b);
        border: none;
        font-weight: bold;
    }

    .edit-link {
        color: #ffeb3b;
    }

    .details-link {
        color: #00e676;
    }

    .delete-link {
        color: #ff1744;
    }

</style>

<!-- Video Background -->
<video autoplay muted loop class="video-bg">
    <source src="https://cdn.pixabay.com/video/2019/10/31/28543-370332702_large.mp4" type="video/mp4">
    Your browser does not support the video tag.
</video>

<!-- Dark Overlay -->
<div class="overlay"></div>

<!-- Page Content -->
<div class="container content-container">
    <h1 class="text-center">Car List</h1>

    <!-- Search and Filter Section -->
    <form method="get" action="@Url.Action("Index", "Cars")" class="filter-box mt-4">
        <div class="row">
            <!-- Search Bar -->
            <div class="col-md-4">
                <label for="searchQuery">Search by Manufacturer or Model</label>
                <input type="text" id="searchQuery" name="searchQuery" class="form-control" placeholder="Search..." value="@Context.Request.Query["searchQuery"]" />
            </div>

            <!-- Manufacturer Filter -->
            <div class="col-md-4">
                <label for="manufacturerId">Select Manufacturer</label>
                <select name="manufacturerId" class="form-control">
                    <option value="">-- All Manufacturers --</option>
                    @foreach (var manufacturer in ViewData["Manufacturers"] as List<string>)
                    {
                        <option value="@manufacturer" selected="@((manufacturer == Context.Request.Query["manufacturerId"].ToString()) ? "selected" : "")">@manufacturer</option>
                    }
                </select>
            </div>

            <!-- Car Type Filter -->
            <div class="col-md-4">
                <label for="carType">Select Car Type</label>
                <select name="carType" class="form-control">
                    <option value="">-- All Car Types --</option>
                    @foreach (var type in ViewData["CarTypes"] as List<car1.Models.CarType>)
                    {
                        <option value="@type.Type" selected="@((type.Type == Context.Request.Query["carType"].ToString()) ? "selected" : "")">@type.Type</option>
                    }
                </select>
            </div>
        </div>

        <button type="submit" class="btn btn-primary mt-3">Search & Filter</button>
    </form>

    <hr />

    <!-- Group Cars by Manufacturer -->
    @foreach (var manufacturerGroup in Model.GroupBy(c => c.ManufacturerName))
    {
        <div class="manufacturer-container">
            <h2 class="text-center">@manufacturerGroup.Key</h2>

            <div class="row">
                @foreach (var car in manufacturerGroup)
                {
                    <div class="col-md-4 mb-4">
                        <div class="car-card p-3">
                            <h4 class="text-center">@car.Model</h4>
                            <p><strong>Type:</strong> @car.Type</p>
                            <p><strong>Engine:</strong> @car.Engine</p>
                            <p><strong>BhP:</strong> @car.Bhp</p>
                            <p><strong>Transmission:</strong> @car.Transmission</p>
                            <p><strong>Price:</strong> $@car.Price</p>

                            <div class="text-center">
                                <a asp-action="Details" asp-route-id="@car.Id" class="details-link">Details</a>
                                @if (!string.Equals(userType?.Trim(), "customer", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a asp-action="Edit" asp-route-id="@car.Id" class="edit-link ml-2">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@car.Id" class="delete-link ml-2">Delete</a>
                                }
                            </div>

                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
